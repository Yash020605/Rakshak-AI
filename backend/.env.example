PORT=5000

# MongoDB Atlas (free tier) — https://cloud.mongodb.com
# Create a free cluster → Database → Connect → Drivers → copy the URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rakshak?retryWrites=true&w=majority

# Twilio — https://twilio.com (free trial gives credits + a test number)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Dashboard basic auth — leave blank to disable auth (dev only)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# No map API key needed — uses OpenStreetMap (Overpass API + Nominatim), 100% free
